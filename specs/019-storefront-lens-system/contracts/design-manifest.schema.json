{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloud-ai/specs/019/contracts/design-manifest.schema.json",
  "title": "DesignManifest (blocks.json)",
  "description": "Per-project design manifest persisted at <projectWorkspace>/blocks.json. Single source of truth cho composition + vibe + version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "designVersion",
    "shakeRevision",
    "seed",
    "vibe",
    "composition",
    "generatedAt",
    "lastIntent"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version để hỗ trợ migration sau này."
    },
    "designVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Tăng mỗi lần redesign."
    },
    "shakeRevision": {
      "type": "integer",
      "minimum": 0,
      "description": "Tăng mỗi shake_design; reset 0 khi redesign."
    },
    "seed": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "sha256(projectId + ':' + designVersion + ':' + shakeRevision)."
    },
    "vibe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["descriptor", "anchors", "story"],
      "properties": {
        "descriptor": { "type": "string", "minLength": 1, "maxLength": 200 },
        "anchors": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true
        },
        "story": { "type": "string", "minLength": 1, "maxLength": 600 }
      }
    },
    "composition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blockId", "variantId", "tier", "position"],
        "properties": {
          "blockId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "variantId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "tier": { "type": "string", "enum": ["high-impact", "supporting"] },
          "position": { "type": "integer", "minimum": 0 },
          "rankRationale": { "type": ["string", "null"], "maxLength": 400 }
        },
        "allOf": [
          {
            "if": { "properties": { "tier": { "const": "high-impact" } } },
            "then": { "required": ["rankRationale"], "properties": { "rankRationale": { "type": "string", "minLength": 1 } } }
          }
        ]
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp."
    },
    "lastIntent": {
      "type": "string",
      "enum": ["init", "update_token", "update_no_design", "redesign", "shake_design"]
    }
  }
}
