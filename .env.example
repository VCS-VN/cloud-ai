# Database
DATABASE_URL=postgres://user:password@localhost:5432/cloud_ai

# OpenAI server-only streaming config
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=60000

# Legacy generic AI config kept as optional fallback during migration
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=60000

# Firebase client (public browser config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Admin (server only)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_CHECK_REVOKED=false

# App session (server only, minimum 32 characters)
SESSION_SECRET=change-me-to-a-random-32-character-secret
SESSION_MAX_AGE_SECONDS=604800
# AI Agent Orchestrator
OPENAI_API_KEY=
OPENAI_MODEL_PLANNER=
OPENAI_MODEL_CODER=
OPENAI_MODEL_SUMMARY=
AGENT_MAX_REPAIR_ATTEMPTS=2
AGENT_MAX_CONTEXT_FILES=12
AGENT_MAX_CONTEXT_CHARS=120000
AGENT_ENABLE_SANDBOX_VALIDATION=true
AGENT_MAX_RUNS_PER_MINUTE=12
AGENT_MAX_PROMPT_CHARS=12000

OAUTH_UI_ORIGIN=https://oauth.myepis.cloud